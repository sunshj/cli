{
  "name": "sunshj",
  "version": "1.0.19",
  "description": "供创建个人预设starter、配置项目使用",
  "type": "module",
  "license": "ISC",
  "author": "sunshj",
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "bin": {
    "sun": "bin/cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "start:create": "tsup --silent --onSuccess \"node dist/index.js create example-app\"",
    "start:config": "tsup --silent --onSuccess \"node dist/index.js config\"",
    "start:new": "tsup --silent --onSuccess \"node dist/index.js new example-app\"",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "commit": "git-cz"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.2.3",
    "inquirer": "^9.2.17",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@sunshj/commitlint-config": "^1.0.0",
    "@sunshj/eslint-config": "^1.0.6",
    "@sunshj/prettier-config": "^1.0.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.12.2",
    "bumpp": "^9.4.0",
    "commitizen": "^4.3.0",
    "commitlint": "^18.6.1",
    "cz-git": "^1.9.1",
    "eslint": "^8.57.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "simple-git-hooks": "^2.11.1",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prettier": "@sunshj/prettier-config",
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx --no-install commitlint --config commitlint.config.js --edit $1"
  }
}
