{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "#*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipDefaultLibCheck": true
  }
}
